<?xml version="1.0" encoding="UTF-8"?>
<!--
    RLQShell MSI installer definition (WiX v6, dual-purpose per-user / per-machine)

    The user chooses the install scope at runtime via WixUI_Advanced's
    InstallScopeDlg. With MSIINSTALLPERUSER=1 Windows Installer automatically
    redirects ProgramFiles64Folder to %LocalAppData%\Programs and the
    ProgramMenu/Desktop folders to their per-user variants, so no separate
    directory tree is needed.

    Build-time variables (pass with `-d Name=Value`):
      Version        e.g. 0.1.0
      SourceExe      absolute path to dist/RLQShell.exe
      IconFile       absolute path to rlqshell/resources/images/app_icon.ico
      LicenseRtf     absolute path to installer/License.rtf
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="RLQShell"
           Manufacturer="RLQShell Contributors"
           Version="$(var.Version)"
           UpgradeCode="3ADAE43B-5083-4B8A-8844-5A51E7AD6174"
           Scope="perUserOrMachine"
           Compressed="yes"
           Codepage="1250"
           Language="1045"
           InstallerVersion="500">

    <SummaryInformation Description="RLQShell – modern SSH client with private-cloud sync"
                        Manufacturer="RLQShell Contributors" />

    <!-- Upgrades: any older version is replaced cleanly -->
    <MajorUpgrade DowngradeErrorMessage="Nowsza wersja RLQShell jest już zainstalowana. Odinstaluj ją najpierw, aby kontynuować." />

    <!-- Everything goes in a single embedded cab -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Icon used in Add/Remove Programs and shortcuts -->
    <Icon Id="RLQShell.ico" SourceFile="$(var.IconFile)" />
    <Property Id="ARPPRODUCTICON" Value="RLQShell.ico" />
    <Property Id="ARPHELPLINK" Value="https://update.lesinski.it/rlqshell/" />
    <Property Id="ARPURLINFOABOUT" Value="https://update.lesinski.it/rlqshell/" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <!--
        Detect an existing per-machine installation by looking for the
        registry marker written by the PerMachineMarker component below.
        When found, force ALLUSERS=1 so MajorUpgrade matches the same
        scope and upgrades in-place instead of installing a second copy.
    -->
    <Property Id="PREV_PERMACHINE">
      <RegistrySearch Id="FindPrevPerMachine"
                      Root="HKLM"
                      Key="Software\RLQShell"
                      Name="InstallScope"
                      Type="raw" />
    </Property>

    <SetProperty Id="ALLUSERS"         Value="1" Before="FindRelatedProducts" Condition="PREV_PERMACHINE" Sequence="first" />
    <SetProperty Id="MSIINSTALLPERUSER" Value="" Before="FindRelatedProducts" Condition="PREV_PERMACHINE" Sequence="first" />

    <!--
        Properties consumed by WixUI_Advanced's InstallScopeDlg.

        ApplicationFolderName - folder name appended to the chosen base dir.
        WixAppFolder          - default selection in the scope radio buttons:
                                WixPerMachineFolder or WixPerUserFolder.
                                Defaulting to per-machine matches the behaviour
                                of older RLQShell builds.
    -->
    <Property Id="ApplicationFolderName" Value="RLQShell" />
    <Property Id="WixAppFolder" Value="WixPerMachineFolder" />

    <!--
        Install into %ProgramFiles%\RLQShell (per-machine) or
        %LocalAppData%\Programs\RLQShell (per-user).

        WixUI_Advanced's SetApplicationFolder custom action resolves
        WixPerMachineFolder → ProgramFilesFolder, so the directory tree
        must use ProgramFilesFolder (not ProgramFiles64Folder). On x64
        Windows with an x64 package both resolve to C:\Program Files.
    -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="APPLICATIONFOLDER" Name="RLQShell">
        <Directory Id="FreeRDPFolder" Name="freerdp" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="RLQShell" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!--
        Components

        MainExecutable   - always installed (core feature)
        StartMenuShortcut - optional feature, user toggles checkbox
        DesktopShortcut  - optional feature, user toggles checkbox
    -->

    <Component Id="MainExecutable"
               Directory="APPLICATIONFOLDER"
               Guid="7A2E9C4D-1B56-4F8E-9A3B-C5D7E8F9A012">
      <File Id="RLQShellExe"
            Name="RLQShell.exe"
            Source="$(var.SourceExe)"
            KeyPath="yes" />
    </Component>

    <!--
        FreeRDP — bundled so smart card / drive / printer redirection works
        out of the box without a separate install. Files are staged into
        installer/freerdp/ by installer/fetch-freerdp.ps1; the build script
        passes the absolute path via -d FreeRDPDir=...
    -->
    <ComponentGroup Id="FreeRDPFiles" Directory="FreeRDPFolder">
      <Files Include="$(var.FreeRDPDir)\**" />
    </ComponentGroup>

    <Component Id="StartMenuShortcut"
               Directory="ApplicationProgramsFolder"
               Guid="F1B2A3C4-D5E6-4789-A0B1-C2D3E4F50617">
      <Shortcut Id="ApplicationStartMenuShortcut"
                Name="RLQShell"
                Description="Modern SSH client with private-cloud sync"
                Target="[APPLICATIONFOLDER]RLQShell.exe"
                WorkingDirectory="APPLICATIONFOLDER"
                Icon="RLQShell.ico" />
      <RemoveFolder Id="CleanUpApplicationProgramsFolder"
                    Directory="ApplicationProgramsFolder"
                    On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\RLQShell\Installer"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut"
               Directory="DesktopFolder"
               Guid="9E8D7C6B-5A49-4382-B716-0F1E2D3C4B5A">
      <Shortcut Id="ApplicationDesktopShortcut"
                Name="RLQShell"
                Description="Modern SSH client with private-cloud sync"
                Target="[APPLICATIONFOLDER]RLQShell.exe"
                WorkingDirectory="APPLICATIONFOLDER"
                Icon="RLQShell.ico" />
      <RegistryValue Root="HKCU"
                     Key="Software\RLQShell\Installer"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!--
        Per-machine scope marker: writes to HKLM so the *next* installer
        run can detect the existing scope via RegistrySearch (above) and
        force ALLUSERS=1 for a clean MajorUpgrade. Only installed when
        the user picks "all users" (MSIINSTALLPERUSER is empty/0).
    -->
    <Component Id="PerMachineMarker"
               Directory="APPLICATIONFOLDER"
               Guid="A1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E"
               Condition="NOT MSIINSTALLPERUSER">
      <RegistryValue Root="HKLM"
                     Key="Software\RLQShell"
                     Name="InstallScope"
                     Type="string"
                     Value="perMachine"
                     KeyPath="yes" />
    </Component>

    <!--
        Feature tree

        Core is mandatory (AllowAbsent="no"). The two shortcut sub-features
        stay in the tree so they can still be toggled from the command line
        via ADDLOCAL/REMOVE, even though WixUI_Advanced does not expose a
        feature-selection dialog.
    -->
    <Feature Id="Core"
             Title="RLQShell (wymagane)"
             Description="Aplikacja główna RLQShell."
             Level="1"
             AllowAbsent="no"
             ConfigurableDirectory="APPLICATIONFOLDER">
      <ComponentRef Id="MainExecutable" />
      <ComponentGroupRef Id="FreeRDPFiles" />
      <ComponentRef Id="PerMachineMarker" />

      <Feature Id="StartMenuShortcutFeature"
               Title="Skrót w menu Start"
               Description="Dodaje skrót do RLQShell w menu Start."
               Level="1">
        <ComponentRef Id="StartMenuShortcut" />
      </Feature>

      <Feature Id="DesktopShortcutFeature"
               Title="Skrót na pulpicie"
               Description="Dodaje skrót do RLQShell na pulpicie."
               Level="1">
        <ComponentRef Id="DesktopShortcut" />
      </Feature>
    </Feature>

    <!--
        WixUI_Advanced adds an InstallScopeDlg where the user picks
        "install for me only" vs "install for all users". Requires
        ApplicationFolderName + WixAppFolder above.

        Known WiX bug (wixtoolset/discussions#7624): the built-in
        WixSetDefaultPerMachineFolder / WixSetDefaultPerUserFolder custom
        actions resolve APPLICATIONFOLDER incorrectly when
        Scope="perUserOrMachine". The two CustomActions below run
        immediately after and override with the correct paths.
    -->
    <ui:WixUI Id="WixUI_Advanced" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <!-- Fix broken folder resolution in WixUI_Advanced (per-machine) -->
    <CustomAction Id="FixPerMachineFolder"
                  Property="APPLICATIONFOLDER"
                  Value="[ProgramFilesFolder][ApplicationFolderName]" />

    <!-- Fix broken folder resolution in WixUI_Advanced (per-user) -->
    <CustomAction Id="FixPerUserFolder"
                  Property="APPLICATIONFOLDER"
                  Value="[LocalAppDataFolder]Programs\[ApplicationFolderName]" />

    <InstallUISequence>
      <Custom Action="FixPerMachineFolder"
              After="WixSetDefaultPerMachineFolder"
              Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;" />
      <Custom Action="FixPerUserFolder"
              After="WixSetDefaultPerUserFolder"
              Condition="WixAppFolder = &quot;WixPerUserFolder&quot;" />
    </InstallUISequence>

    <InstallExecuteSequence>
      <Custom Action="FixPerMachineFolder"
              After="WixSetDefaultPerMachineFolder"
              Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;" />
      <Custom Action="FixPerUserFolder"
              After="WixSetDefaultPerUserFolder"
              Condition="WixAppFolder = &quot;WixPerUserFolder&quot;" />
    </InstallExecuteSequence>

  </Package>
</Wix>
